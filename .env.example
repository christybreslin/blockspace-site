# Copy to .env and fill in. The .env file is gitignored — never commit it.

# Execution-layer JSON-RPC endpoint (the server reads block + receipt data from here).
EL_RPC_URL=https://your-el-rpc.example
# Bearer token for the endpoint (sent as "Authorization: Bearer <token>"). Leave blank if none.
EL_RPC_TOKEN=

# Optional:
# PORT=8137              # port to serve on (default 8137)
# RPC_VERIFY=true        # set false (or INSECURE=1 env) only if the endpoint uses a self-signed cert
